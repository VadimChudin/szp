# Smart Zones Pro — Environment Configuration
# Copy this file to `.env` (in the same folder) and fill in your values.
# All variables are optional — sensible defaults are baked into the app.
# The application reads `.env` at startup; restart after editing.

# ──────────────────────────────────────────────────────────────────────
# Telegram bot — alerts on zone touches and daily summaries
# Create a bot via @BotFather in Telegram, paste the token below.
# To learn your chat id: send a message to your bot, then visit
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# ──────────────────────────────────────────────────────────────────────
ENABLE_TELEGRAM=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ──────────────────────────────────────────────────────────────────────
# Trading instrument
# ──────────────────────────────────────────────────────────────────────
SYMBOL=XAUUSD
BROKER_UTC_OFFSET=3

# ──────────────────────────────────────────────────────────────────────
# Algorithm output limits
#   MAX_ZONES_ON_CHART — top-N strongest zones to render
#   MIN_ZONE_SCORE     — only zones with score >= this are shown
# ──────────────────────────────────────────────────────────────────────
MAX_ZONES_ON_CHART=5
MIN_ZONE_SCORE=11

# ──────────────────────────────────────────────────────────────────────
# Data source — "mt5" (live, via MetaTrader Python API) or "csv" (offline)
# ──────────────────────────────────────────────────────────────────────
DATA_SOURCE=mt5

# ──────────────────────────────────────────────────────────────────────
# Optional: override the install dir (only set if you moved the app
# after install and want to keep using its data files in-place).
# ──────────────────────────────────────────────────────────────────────
# SZP_BASE_DIR=C:\Program Files\SmartZonesPro

# ──────────────────────────────────────────────────────────────────────
# Optional: Binance futures (public, no key needed for the free tier we use).
# Reserved for future expansion (rate-limit headers, dedicated proxy, etc).
# ──────────────────────────────────────────────────────────────────────
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
